#!/bin/bash

# Generate a daily work report by summarizing git commits across Maul repos
# Uses Claude to create a lively, emoji-rich summary for sharing with the team

REPOS_DIR="${MAUL_REPOS_DIR:-$HOME/Documents/Maul/Repos}"
read -ra REPOS <<< "${MAUL_REPOS:-maul-backend foodie-web kitchen-web dashboard}"
AUTHOR="${MAUL_GIT_AUTHOR:-astradur@maul.is}"
DATE="${1:-today}"

echo "=== Daily Report Generator ==="
echo "Date: $DATE"
echo "Author: $AUTHOR"
echo "Repos dir: $REPOS_DIR"
echo "Scanning repos: ${REPOS[*]}"
echo "Search: --all --shortstat"
echo ""

commits=""

for repo in "${REPOS[@]}"; do
    repo_path="$REPOS_DIR/$repo"
    if [ ! -d "$repo_path/.git" ]; then
        echo "  [$repo] skipped (not found)"
        continue
    fi

    repo_commits=$(/usr/bin/git -C "$repo_path" log \
        --all \
        --author="$AUTHOR" \
        --since="$DATE 00:00" \
        --until="$DATE 23:59" \
        --format="%h %s" \
        --shortstat \
        2>/dev/null)

    if [ -n "$repo_commits" ]; then
        commit_count=$(/usr/bin/git -C "$repo_path" log \
            --all \
            --author="$AUTHOR" \
            --since="$DATE 00:00" \
            --until="$DATE 23:59" \
            --oneline \
            2>/dev/null | wc -l | tr -d ' ')
        echo "  [$repo] $commit_count commit(s) found"
        commits+="
## $repo
$repo_commits
"
    else
        echo "  [$repo] no commits"
    fi
done

echo ""

# Gather merged PRs across repos
prs=""
echo "Scanning for merged PRs..."
for repo in "${REPOS[@]}"; do
    repo_path="$REPOS_DIR/$repo"
    if [ ! -d "$repo_path/.git" ]; then
        continue
    fi

    # Get the GitHub remote to determine owner/repo
    remote_url=$(/usr/bin/git -C "$repo_path" remote get-url origin 2>/dev/null)
    if [ -z "$remote_url" ]; then
        continue
    fi

    # Resolve DATE to YYYY-MM-DD for GitHub search
    if [ "$DATE" = "today" ]; then
        search_date=$(date '+%Y-%m-%d')
    elif [ "$DATE" = "yesterday" ]; then
        search_date=$(date -v-1d '+%Y-%m-%d')
    else
        # Try parsing as YYYY-MM-DD, fall back to using date string as-is
        search_date=$(date -j -f '%Y-%m-%d' "$DATE" '+%Y-%m-%d' 2>/dev/null || echo "$DATE")
    fi

    repo_prs=$(gh pr list \
        --repo "$remote_url" \
        --author "@me" \
        --state merged \
        --search "merged:$search_date" \
        --json number,title,mergedAt \
        --template '{{range .}}#{{.number}} {{.title}} (merged {{timeago .mergedAt}}){{"\n"}}{{end}}' \
        2>/dev/null)

    if [ -n "$repo_prs" ]; then
        pr_count=$(echo "$repo_prs" | wc -l | tr -d ' ')
        echo "  [$repo] $pr_count PR(s) merged"
        prs+="
## $repo (PRs)
$repo_prs
"
    fi
done

echo ""

if [ -z "$commits" ] && [ -z "$prs" ]; then
    echo "No commits or PRs found for $DATE. Nothing to report."
    exit 0
fi

prompt="Here are my git commits and merged PRs from today across our work repositories:
$commits
$prs

Please write a daily work report summarizing what I accomplished today. The report should be:
- Written for sharing with superiors and colleagues in a team chat
- Organized by project/repo
- Use plenty of emojis to make it lively and fun to read
- Keep it concise but informative
- Use bullet points
- Start with a greeting and end with a sign-off
- Don't include commit hashes, just summarize the work done
- IMPORTANT: Group related commits into a single high-level accomplishment. If multiple commits are clearly part of the same feature or task (e.g. building it, then refactoring/moving it, then fixing it), describe the end result as one bullet point, not each step separately. Focus on what was delivered, not the journey to get there."

echo "--- Prompt being sent to Claude ---"
echo "$prompt"
echo "--- End of prompt ---"
echo ""
echo "Generating summary..."
echo ""

claude --dangerously-skip-permissions -p "$prompt"
